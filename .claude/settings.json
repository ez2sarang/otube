{
  "autoCompactEnabled": true,
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(uv *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ez2sarang/Documents/dev/ai/offline-thinking/.collar/collar-dispatcher.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/ez2sarang/Documents/dev/ai/offline-thinking/.collar/collar-dispatcher.sh'",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
